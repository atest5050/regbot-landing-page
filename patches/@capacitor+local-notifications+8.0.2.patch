+// JSTypes.coerceDictionaryToJSObject is behind $NonescapableTypes in Capacitor 8's swiftinterface,
+// so we provide a local equivalent that works under Swift 5 language mode.
+func coerceDictionaryToJSObject(_ dict: [AnyHashable: Any]?) -> JSObject? {
+    guard let dict = dict else { return nil }
+    var result: JSObject = [:]
+    for (key, value) in dict {
+        guard let strKey = key as? String else { continue }
+        if let v = value as? String            { result[strKey] = v }
+        else if let v = value as? Bool         { result[strKey] = v }
+        else if let v = value as? Int          { result[strKey] = v }
+        else if let v = value as? Double       { result[strKey] = v }
+        else if let v = value as? NSNumber     { result[strKey] = v }
+        else if let v = value as? NSNull       { result[strKey] = v }
+        else if let v = value as? Date         { result[strKey] = v }
+        else if let v = value as? [AnyHashable: Any],
+                let nested = coerceDictionaryToJSObject(v) { result[strKey] = nested }
+    }
+    return result
+}
