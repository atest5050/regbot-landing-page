    "cap:test:ios": "npm run build:cap && npx cap run ios --configuration=Debug",
    "cap:test:android": "npm run build:cap && npx cap run android --configuration=Debug",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "store:prepare": "node scripts/store-assets-check.js",
    "store:icons": "node scripts/store-assets-check.js --icons-only",
